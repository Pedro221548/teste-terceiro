rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields:
    //   - firstName: string (required)
    //   - lastName: string (required)
    //   - cpf: string (required)
    //   - birthDate: string
    //   - phone: string (required)
    //   - photoUrl: string
    //   - docUrl: string
    //   - rating: number (required)
    //   - status: string (required, enum: ["PENDING", "ACTIVE", "INACTIVE"])
    //   - complaints: number
    //   - lastAssignmentDate: string
    //   - unavailableDates: list (strings)
    //
    // Collection: clients
    // Fields:
    //   - name: string (required)
    //   - managerName: string (required)
    //   - location: string
    //   - activeScales: number
    //
    // Collection: assignments
    // Fields:
    //   - employeeId: string (required)
    //   - clientId: string (required)
    //   - date: string (required)
    //   - value: number (required)
    //   - status: string (required, enum: ["SCHEDULED", "COMPLETED", "CANCELLED"])
    //
    // Collection: feedbacks
    // Fields:
    //   - assignmentId: string (required)
    //   - employeeId: string (required)
    //   - managerId: string (required)
    //   - rating: number (required)
    //   - comment: string
    //   - date: string (required)
    //
    // Collection: contacts
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - status: string (required, enum: ["PENDING", "CONTACTED"])
    //   - date: string (required)
    //
    // Collection: accessPoints
    // Fields:
    //   - managerName: string (required)
    //   - location: string (required)
    //   - qrCodeValue: string (required)
    //   - createdAt: string (required)
    //
    // Collection: checkIns
    // Fields:
    //   - employeeId: string (required)
    //   - accessPointId: string (required)
    //   - location: string (required)
    //   - timestamp: string (required)
    //   - photoUrl: string (required)
    //   - type: string (required, enum: ["IN", "OUT"])
    //
    // Collection: companyRequests
    // Fields:
    //   - companyId: string (required)
    //   - clientId: string (required)
    //   - employeeIds: list (strings)
    //   - quantity: number (required)
    //   - date: string (required)
    //   - status: string (required, enum: ["PENDING", "ACCEPTED", "REJECTED"])
    //   - createdAt: string (required)
    //
    // Collection: notifications
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - type: string (required, enum: ["ASSIGNMENT", "INFO"])
    //   - read: bool (required)
    //   - createdAt: string (required)
    //   - link: string
    //   - assignmentId: string
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum: ["AGENCY", "COMPANY", "EMPLOYEE", "REGISTRATION", "COMPANY_REGISTRATION"])
    //   - forcePasswordChange: bool
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'AGENCY') ||
         (request.auth.token.email == "pedroass.11577@gmail.com"));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCompany() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'COMPANY') ||
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function isEmployee() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'EMPLOYEE') ||
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['role', 'email', 'createdAt']) &&
             data.role in ['AGENCY', 'COMPANY', 'EMPLOYEE', 'REGISTRATION', 'COMPANY_REGISTRATION'] &&
             data.email is string &&
             data.createdAt is string &&
             (!('forcePasswordChange' in data) || data.forcePasswordChange is bool);
    }

    function isValidCompanyRequest(data) {
      return hasRequiredFields(['companyId', 'clientId', 'status', 'createdAt']) &&
             data.companyId is string &&
             data.clientId is string &&
             data.status in ["PENDING", "ACCEPTED", "REJECTED"] &&
             data.createdAt is string;
    }

    function isValidNotification(data) {
      return hasRequiredFields(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string &&
             data.type in ["ASSIGNMENT", "INFO"] &&
             data.read is bool &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if (isAdmin() || isOwner(userId)) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isOwner(employeeId) || isCompany();
      allow delete: if isAdmin() || isOwner(employeeId);
    }

    match /employeeRegistrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin() || isCompany();
      allow delete: if isAdmin() || isCompany();
    }

    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin() || isCompany() || isEmployee();
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /accessPoints/{accessPointId} {
      allow read: if true;
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin() || isCompany();
      allow delete: if isAdmin() || isCompany();
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /companyUsers/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    function isValidCheckIn(data) {
      return hasRequiredFields(['employeeId', 'accessPointId', 'location', 'timestamp', 'photoUrl', 'type']) &&
             data.employeeId is string &&
             data.accessPointId is string &&
             data.location is string &&
             data.timestamp is string &&
             data.photoUrl is string &&
             data.type in ["IN", "OUT"];
    }

    match /checkIns/{checkInId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidCheckIn(request.resource.data);
      allow update: if (isAdmin() || isCompany()) && isValidCheckIn(request.resource.data);
      allow delete: if isAdmin();
    }

    match /companyRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isCompany();
      allow delete: if isAdmin();
    }

    function canReadNotification(notificationUserId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      
      return isAdmin() || 
             notificationUserId == request.auth.uid || 
             notificationUserId == 'AGENCY' || 
             (userDoc.role == 'COMPANY' && notificationUserId == 'COMPANY_' + userDoc.companyId);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && canReadNotification(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
